{
    "info": {
        "name": "Roster API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "baseUrl", "value": "http://127.0.0.1:3001" },
        { "key": "token", "value": "" },
        { "key": "tenantId", "value": "" }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "if (res.token) pm.collectionVariables.set('token', res.token);",
                                    "if (res.schools && res.schools[0]) pm.collectionVariables.set('tenantId', res.schools[0].db_hash);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "url": "{{baseUrl}}/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\"\n}"
                        }
                    }
                },
                {
                    "name": "Register Account",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/auth/register",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"teacher@test.com\",\n  \"password\": \"password123\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "GraphQL",
            "item": [
                {
                    "name": "Schools — Query schools",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"{ schools { id name dbHash createdAt } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Users — Query users",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"{ users { id accountId name role createdAt } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Users — Create user",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { createUser(input: { accountId: 1, name: \\\"Admin\\\", role: \\\"admin\\\" }) { id name role } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Users — Update user",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { updateUser(id: 1, input: { name: \\\"Admin\\\", role: \\\"admin\\\" }) { id name role } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Users — Delete user",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { deleteUser(id: 1) }\"\n}"
                        }
                    }
                },
                {
                    "name": "Students — Query students",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"{ students { id name code photoUrl createdAt } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Students — Create student",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { createStudent(input: { name: \\\"João Silva\\\", code: \\\"STU001\\\" }) { id name code } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Students — Update student",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { updateStudent(id: 1, input: { name: \\\"João Silva\\\", code: \\\"STU001\\\" }) { id name code } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Students — Delete student",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { deleteStudent(id: 1) }\"\n}"
                        }
                    }
                },
                {
                    "name": "Classes — Query classes",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"{ classes { id name userId createdAt } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Classes — Create class",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { createClass(input: { name: \\\"Turma A\\\" }) { id name userId } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Classes — Update class",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { updateClass(id: 1, input: { name: \\\"Turma A\\\" }) { id name } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Classes — Delete class",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { deleteClass(id: 1) }\"\n}"
                        }
                    }
                },
                {
                    "name": "Classes — Add student to class",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { addStudentToClass(classId: 1, studentId: 1) }\"\n}"
                        }
                    }
                },
                {
                    "name": "Classes — Remove student from class",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { removeStudentFromClass(classId: 1, studentId: 1) }\"\n}"
                        }
                    }
                },
                {
                    "name": "Attendance — Query current session",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"{ currentSession { id classId openedBy openedAt closedAt } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Attendance — Open session",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { openSession(classId: 1) { id classId openedAt closedAt } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Attendance — Register attendance",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { registerAttendance(studentCode: \\\"STU001\\\") { id studentId registeredAt } }\"\n}"
                        }
                    }
                },
                {
                    "name": "Attendance — Close session",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/graphql",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"query\": \"mutation { closeSession(id: 1) { id openedAt closedAt } }\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Cards",
            "item": [
                {
                    "name": "Issue card",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/cards/1/issue"
                    }
                },
                {
                    "name": "Get current card",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": "{{baseUrl}}/cards/1"
                    }
                }
            ]
        },
        {
            "name": "Reports",
            "item": [
                {
                    "name": "Monthly attendance report",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/reports/classes/1?month=3&year=2026",
                            "host": ["{{baseUrl}}"],
                            "path": ["reports", "classes", "1"],
                            "query": [
                                { "key": "month", "value": "3" },
                                { "key": "year", "value": "2026" }
                            ]
                        }
                    }
                }
            ]
        }
    ]
}
